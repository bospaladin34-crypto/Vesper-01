#!/data/data/com.termux/files/usr/bin/bash
set -e
ROOT=~/nephilim
cd $ROOT

case "$1" in
  switch)
    SPEC=${2:-nephilim}
    echo "→ $SPEC"
    cd compiler && cargo run --quiet --../${SPEC}.spec
    cd../core && cargo build --quiet
    echo "$SPEC" >../.current_spec
    ;;
  build)
    SPEC=$(cat.current_spec 2>/dev/null || echo "nephilim")
    cd compiler && cargo run --quiet --../${SPEC}.spec
    cd../core && cargo build --quiet
    ;;
  info)
    cd core && cargo run --quiet
    ;;
  points)
    N=${2:-100}
    SPEC=$(cat.current_spec 2>/dev/null || echo "nephilim")
    cd core
    OUT=$(cargo run --quiet -- $N)
    echo "$OUT" | head -20
    echo "$OUT" | awk '/^x,y,z/{p=1;print;next} p' >../points_${SPEC}_${N}.csv
    echo "... CSV saved"
    ;;
  braid)
    N=${2:-20}
    cd core
    OUT=$(cargo run --quiet -- $N)
    echo "$OUT" | awk '/^---BRAID---/{p=1;next} p'
    ;;
  compare)
    N=${2:-100}
    $0 switch nephilim >/dev/null
    $0 points $N >/dev/null
    $0 switch erdos >/dev/null
    $0 points $N >/dev/null
    echo "Nephilim vs Erdos (first 5):"
    echo "NEPHILIM:"; head -6 points_nephilim_${N}.csv | tail -5
    echo "ERDOS:"; head -6 points_erdos_${N}.csv | tail -5
    ;;
  *)
    echo "usage: nephilim switch|build|info|points [N]|braid [N]|compare [N]"
    ;;
esac
