#!/bin/bash
CORE=./core/target/release/nephilim-core
LOG=~/nephilim/ledger.log

case "$1" in
  switch)
    echo "$2.spec" >.current_spec
    echo "→ $2"
    $CORE --info
    ;;
  hash)
    shift; $CORE "$@"
    ;;
  braid)
    shift
    braid_word="$*"
    echo "Artin Braid: $braid_word"
    out=$($CORE "$braid_word")
    echo "$out"
    echo "  ↳ braid word hashed through SU5_aperiodic"
    ;;
  log)
    shift
    txt="$*"
    out=$($CORE "$txt")
    ts=$(date -Iseconds)
    echo "[$ts] $txt => $out" | tee -a $LOG
    ;;
  log-braid)
    shift
    braid_word="$*"
    out=$($CORE "$braid_word")
    ts=$(date -Iseconds)
    echo "[$ts] [BRAID] $braid_word => $out" | tee -a $LOG
    ;;
  status)
    echo "--- Nephilim Status ---"
    echo "spec: $(cat.current_spec 2>/dev/null)"
    $CORE --info
    echo "ledger: $(wc -l <$LOG 2>/dev/null || echo 0) entries"
    ;;
  serve)
    python3 server.py
    ;;
esac
